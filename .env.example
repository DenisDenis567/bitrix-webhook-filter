# Railway автоматически назначает PORT
# PORT=3000

# ==================== Bitrix24 → Make.com (существующий функционал) ====================

# URL вебхука Make.com для отправки отфильтрованных событий
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook-url-here

# ID типа сущности для фильтрации (по умолчанию 1064)
# ALLOWED_ENTITY_TYPE_ID=1064

# ==================== Google Sheets → Bitrix24 (новый функционал) ====================

# URL вебхука Bitrix24 для обновления элементов (REST API)
# Формат: https://ваш-портал.bitrix24.ru/rest/USER_ID/WEBHOOK_TOKEN/crm.item.update
BITRIX_WEBHOOK_URL=https://mygenetics.bitrix24.ru/rest/143/icymcjs5ft1ogq83/crm.item.update

# ID стадии для перемещения оплаченных элементов (по умолчанию DT1064_28:SUCCESS)
BITRIX_PAID_STAGE_ID=DT1064_28:SUCCESS
