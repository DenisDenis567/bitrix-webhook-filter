# Порт сервера
PORT=3000

# Битрикс24 webhook URL (создать в Битрикс > Разработчикам > Вебхуки)
# Нужны права: tasks
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-secret-key/

# Telegram бот
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Расписание отправки отчёта (cron формат)
# По умолчанию: 19:00 по будням
REPORT_CRON=0 19 * * 1-5

# Сотрудники для отслеживания (JSON)
# Ключ = ID сотрудника в Битрикс24, значение = имя
EMPLOYEES={"1":"Иванов Иван","2":"Петров Пётр"}

# Папка для хранения данных
DATA_DIR=./data
